# =============================================================================
#  mailbox-go-live — secrets locaux
# =============================================================================
#  COPIE ce fichier en `scripts/mailbox-go-live.env` (gitignored) et remplis.
#  Le script `scripts/mailbox-go-live.sh` source automatiquement ce fichier.
#
#  PRÉREQUIS Supabase (manuel) :
#    1. Storage -> New bucket -> nom "email-attachments" -> DÉCOCHER "Public"
#    2. Settings -> API -> copier le "Project URL" et la clé "service_role"
# =============================================================================

# URL du projet Supabase (Settings -> API -> Project URL)
SUPABASE_URL="https://pubrtdtigucvhjydtifo.supabase.co"

# Clé service_role Supabase (Settings -> API -> service_role) — JAMAIS commit
SUPABASE_SERVICE_KEY="eyJ...secret-service-role-key..."

# Secret partagé webhook <-> Worker Cloudflare. Générer avec :
#   openssl rand -base64 32
# Doit être IDENTIQUE côté Cloudflare Worker.
INBOUND_EMAIL_SECRET="paste-base64-secret-here"

# Email mailbox du praticien (doit matcher la route Cloudflare Email Routing)
