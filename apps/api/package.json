    "@prisma/client": "^5.13.0",
    "@reset/shared": "workspace:*",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/nodemailer": "^8.0.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.0",
    "fastify": "^4.27.0",
    "fastify-plugin": "^5.1.0",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^8.0.7",
    "pino": "^9.1.0",
    "pino-pretty": "^11.0.0",
