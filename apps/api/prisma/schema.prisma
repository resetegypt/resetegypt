// Reset Egypt — Prisma schema
// Generated from spec docs/superpowers/specs/2026-05-11-reset-egypt-design.md (lines 441-682)

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x", "debian-openssl-3.0.x"]
}

// Supabase: DATABASE_URL = pooler port 6543 (?pgbouncer=true&connection_limit=1)
//           DIRECT_URL   = direct port 5432 (utilisé uniquement pour les migrations)
// En local sans Supabase, mettre la même valeur dans les deux.
datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                String   @id @default(uuid())
  email             String   @unique
  passwordHash      String
  role              Role     @default(SECRETARY)
  firstName         String
  lastName          String
  phone             String?
  preferredLanguage String   @default("fr")
  isActive          Boolean  @default(true)
  isLocked          Boolean  @default(false)
  failedAttempts    Int      @default(0)
  lastLoginAt       DateTime?
  passwordChangedAt DateTime @default(now())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  appointments         Appointment[]   @relation("PractitionerAppointments")
  createdPatients      Patient[]       @relation("CreatedBy")
  preferredByPatients  Patient[]       @relation("PreferredPractitioner")
  payments             Payment[]       @relation("PaymentCreatedBy")
  auditLogs            AuditLog[]
  systemSettings       SystemSetting[]
  createdMedicalRecords  MedicalRecord[] @relation("MedicalRecordCreatedBy")
  finalizedMedicalRecords MedicalRecord[] @relation("MedicalRecordFinalizedBy")
  followUpNotes          FollowUpNote[]  @relation("FollowUpNoteAuthor")
  scoreSnapshots         ScoreSnapshot[] @relation("ScoreSnapshotTakenBy")
  mailbox    Mailbox?
  sentEmails EmailMessage[] @relation("EmailSentBy")
}

enum Role {
  ADMIN
  PRACTITIONER
  SECRETARY
}

model Patient {
  id                      String        @id @default(uuid())
  firstName               String
  lastName                String
  dateOfBirth             DateTime?
  age                     Int?
  gender                  Gender?
  phone                   String        @unique
  whatsapp                String?
  email                   String?
  address                 String?
  governorate             String?
  profession              String?
  maritalStatus           String?
  acquisitionSource       String[]
  primaryAddiction        Addiction
  previousAttempts        String?
  motivationLevel         String?
  emergencyContact        Json?
  consents                Json
  preferredLanguage       String        @default("fr")
  preferredPractitionerId String?
  preferredPractitioner   User?         @relation("PreferredPractitioner", fields: [preferredPractitionerId], references: [id])
  createdById             String
  createdBy               User          @relation("CreatedBy", fields: [createdById], references: [id])
  status                  PatientStatus @default(ACTIVE)
  // Avatar : URL absolue (CDN) OU data URL base64 redimensionnée client-side.
  // null => initiales du nom (fallback).
  avatarUrl               String?
  // Tags libres : VIP, "paie en retard", "allergie laser", "vegan", etc.
  // Multi-valeur, normalisés en lowercase à la sauvegarde.
  tags                    String[]      @default([])
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt

  appointments   Appointment[]
  medicalRecord  MedicalRecord?
  payments       Payment[]
  messages       Message[]
  followUpNotes  FollowUpNote[]
  waitingEntries WaitingList[]
  scoreSnapshots ScoreSnapshot[]
  emailThreads EmailThread[]

  @@index([phone])
  @@index([lastName, firstName])
}

enum Gender {
  MALE
  FEMALE
}

enum Addiction {
  TOBACCO
  DRUGS
  ALCOHOL
  SUGAR
  STRESS
}

enum PatientStatus {
  ACTIVE
  ARCHIVED
  LOST
}

model Appointment {
  id             String            @id @default(uuid())
  patientId      String
  patient        Patient           @relation(fields: [patientId], references: [id])
  practitionerId String
  practitioner   User              @relation("PractitionerAppointments", fields: [practitionerId], references: [id])
  scheduledAt    DateTime
  duration       Int               @default(40)
  service        Addiction
  visitType      VisitType
  status         AppointmentStatus @default(SCHEDULED)
  source         String
  price          Decimal           @db.Decimal(10, 2)
  notes          String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  payment       Payment?

  @@index([scheduledAt])
  @@index([practitionerId, scheduledAt])
  @@index([patientId, scheduledAt])
}

enum VisitType {
  FIRST
  FOLLOWUP
  CONSOLIDATION
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  // Patient s'est présenté à l'accueil et attend que le médecin l'appelle
  // (transition entre SCHEDULED/CONFIRMED et IN_PROGRESS).
  ARRIVED
  IN_PROGRESS
  COMPLETED
  NO_SHOW
  CANCELLED
}

// Fiche clinique : UNE seule par patient (vs une par RDV avant).
// Créée par le médecin lors de la première séance, éditable en suivi.
// Quand le médecin clique "Terminer", finalizedAt est set — la fiche
// reste éditable (en mode "suivi") mais la version finale est marquée.
model MedicalRecord {
  id        String  @id @default(uuid())
  patientId String  @unique
  patient   Patient @relation(fields: [patientId], references: [id])

  // === Addiction en détail ===
  yearsOfAddiction      Int?
  startedAt             DateTime?
  dailyQuantity         String?
  estimatedCostPerMonth Decimal?    @db.Decimal(10, 2)

  // === Déclencheurs & contexte ===
  triggers           String[]    // chips: stress, social, ennui, anxiete, etc.
  consumptionMoments String?     // textarea
  socialContext      String?     // entourage, conjoint, amis qui consomment
  workContext        String?     // contexte pro

  // === Historique tentatives ===
  previousAttempts     Int?       // nb de tentatives
  longestQuit          String?    // plus longue période d'arrêt
  relapseReasons       String?    // qu'est-ce qui a déclenché la rechute
  methodsTried         String[]   // patchs, gommes, hypnose, etc.

  // === Évaluations psycho-comportementales (0-10) ===
  stressScore       Int?
  anxietyScore      Int?
  cravingScore      Int?
  sleepScore        Int?
  motivationScore   Int?
  selfEsteemScore   Int?

  // === Examen clinique ===
  weight        Float?
  height        Float?
  bmi           Float?
  bloodPressure String?
  heartRate     Int?
  spo2          Int?

  // === Antécédents ===
  medicalHistory     String?
  surgicalHistory    String?
  familyHistory      String?
  currentMedications String?
  allergies          String?

  // === Contre-indications laser ===
  contraindications     String[]
  contraindicationNotes String?

  // === Scores standardisés ===
  fagerstromScore    Int?     // Tabac
  auditScore         Int?     // Alcool
  duditScore         Int?     // Drogues
  yfasScore          Int?     // Sucre
  hadAnxietyScore    Int?     // Hospital Anxiety Depression scale
  hadDepressionScore Int?

  // === Protocole thérapeutique ===
  auricularPoints   String?
  laserDuration     Int?
  sessionFrequency  String?
  estimatedSessions Int?

  // === Objectifs & plan ===
  patientGoals  String?
  treatmentPlan String?

  // === Notes privées (visibles seulement par les médecins) ===
  privateNotes String?

  // === Workflow ===
  createdById   String?
  createdBy     User?     @relation("MedicalRecordCreatedBy", fields: [createdById], references: [id])
  finalizedAt   DateTime? // quand le médecin clique "Terminer"
  finalizedById String?
  finalizedBy   User?     @relation("MedicalRecordFinalizedBy", fields: [finalizedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([patientId])
}

model Payment {
  id             String        @id @default(uuid())
  appointmentId  String?       @unique
  appointment    Appointment?  @relation(fields: [appointmentId], references: [id])
  patientId      String
  patient        Patient       @relation(fields: [patientId], references: [id])
  invoiceNumber  String        @unique
  items          Json
  subtotal       Decimal       @db.Decimal(10, 2)
  discount       Decimal       @default(0) @db.Decimal(10, 2)
  vat            Decimal       @db.Decimal(10, 2)
  total          Decimal       @db.Decimal(10, 2)
  paymentMethod  PaymentMethod
  paymentRef     String?
  etaUuid        String?
  etaHash        String?
  etaSubmittedAt DateTime?
  pdfUrl         String?
  emailSentAt    DateTime?
  emailSentTo    String?
  createdAt      DateTime      @default(now())
  createdById    String
  createdBy      User          @relation("PaymentCreatedBy", fields: [createdById], references: [id])

  @@index([patientId, createdAt])
  @@index([invoiceNumber])
  @@index([createdAt])
}

enum PaymentMethod {
  CASH
  CARD
  VODAFONE_CASH
  INSTAPAY
  FAWRY
  BANK_TRANSFER
}

model Message {
  id           String        @id @default(uuid())
  patientId    String?
  patient      Patient?      @relation(fields: [patientId], references: [id])
  externalId   String?
  channel      Channel
  direction    Direction
  fromAddress  String
  toAddress    String
  content      String
  status       MessageStatus @default(SENT)
  isAuto       Boolean       @default(false)
  templateName String?
  attachments  Json?
  language     String        @default("fr")
  createdAt    DateTime      @default(now())
  readAt       DateTime?

  @@index([patientId, createdAt])
  @@index([channel, createdAt])
}

enum Channel {
  WHATSAPP
  INSTAGRAM
  MESSENGER
  EMAIL
  SMS
}

enum Direction {
  INBOUND
  OUTBOUND
}

enum MessageStatus {
  QUEUED
  SENT
  DELIVERED
  READ
  FAILED
}

model AutomationWorkflow {
  id        String   @id @default(uuid())
  name      String
  trigger   String
  isActive  Boolean  @default(true)
  steps     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  runs AutomationRun[]
}

/// Idempotency + audit trail for fired automation steps.
/// contextKey examples: "appt-{appointmentId}" / "patient-{patientId}-{yyyymmdd}".
model AutomationRun {
  id         String   @id @default(uuid())
  workflowId String
  workflow   AutomationWorkflow @relation(fields: [workflowId], references: [id])
  contextKey String
  stepIndex  Int
  channel    String
  template   String
  status     String   @default("PENDING") // PENDING | SENT | SKIPPED | FAILED
  toAddress  String?
  messageId  String?  // ID retourné par Resend (ou autre provider)
  error      String?
  firedAt    DateTime @default(now())

  @@unique([workflowId, contextKey, stepIndex])
  @@index([firedAt])
  @@index([status])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  resource  String?
  details   Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([action, createdAt])
}

model SystemSetting {
  key         String   @id
  value       Json
  updatedAt   DateTime @updatedAt
  updatedById String?
  updatedBy   User?    @relation(fields: [updatedById], references: [id])
}

model IpWhitelist {
  id          String   @id @default(uuid())
  ipAddress   String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

// Notes de suivi libres au fil des séances (timeline).
// Différent de MedicalRecord (qui est UNE fiche structurée par patient).
// Chaque note est datée, attachée au patient (et optionnellement à un RDV),
// horodatée et signée par son auteur (médecin/secrétaire).
model FollowUpNote {
  id            String       @id @default(uuid())
  patientId     String
  patient       Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  appointmentId String?
  authorId      String
  author        User         @relation("FollowUpNoteAuthor", fields: [authorId], references: [id])
  content       String
  // Tag visuel pour la timeline : observation médicale, note secrétaire, alerte, etc.
  kind          NoteKind     @default(NOTE)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([patientId, createdAt])
}

enum NoteKind {
  NOTE          // note générique
  OBSERVATION   // observation clinique post-séance
  ALERT         // alerte importante (allergie découverte, etc.)
  CALL          // appel téléphonique passé
  RELAPSE       // rechute signalée
}

// Patients en liste d'attente pour un créneau préféré.
// Quand un RDV existant est CANCELLED ou NO_SHOW, on cherche les entries
// matching (service + plage horaire) et on notifie les premiers de la file.
model WaitingList {
  id              String            @id @default(uuid())
  patientId       String
  patient         Patient           @relation(fields: [patientId], references: [id], onDelete: Cascade)
  service         Addiction
  // Préférences de créneau (toutes optionnelles) :
  preferredFrom   DateTime?         // début de la fenêtre acceptable
  preferredTo     DateTime?         // fin de la fenêtre acceptable
  preferredDays   String[]          @default([]) // ['MON', 'TUE', 'SAT', ...]
  preferredHours  String?           // ex: "matin", "après-midi", "18h+"
  practitionerId  String?           // si le patient veut un médecin spécifique
  priority        Int               @default(0) // higher = priorisé
  status          WaitingListStatus @default(WAITING)
  notifiedAt      DateTime?
  notifiedSlotAt  DateTime?         // créneau qu'on a proposé
  bookedAt        DateTime?
  bookedAppointmentId String?
  notes           String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([service, status, createdAt])
  @@index([patientId])
}

enum WaitingListStatus {
  WAITING    // dans la file
  NOTIFIED   // on a envoyé une proposition par email
  BOOKED     // a accepté et un RDV a été créé
  EXPIRED    // créneau passé sans réponse
  CANCELLED  // retiré de la liste
}

// Snapshot des scores 0-10 du patient à un instant T.
// Pris explicitement par le médecin (bouton dans la fiche clinique)
// pour suivre l'évolution séance après séance.
model ScoreSnapshot {
  id              String   @id @default(uuid())
  patientId       String
  patient         Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  stressScore     Int?
  anxietyScore    Int?
  cravingScore    Int?
  sleepScore      Int?
  motivationScore Int?
  selfEsteemScore Int?
  // Note libre attachée au snapshot (ex: "après 3ème séance")
  notes           String?
  takenAt         DateTime @default(now())
  takenById       String?
  takenBy         User?    @relation("ScoreSnapshotTakenBy", fields: [takenById], references: [id])

  @@index([patientId, takenAt])
}

// === Messagerie praticien ===================================================
// Boîte email privée d'un praticien (1 par user ayant une adresse @reset-egypt.com).
// Modèles SÉPARÉS du modèle Message (Inbox d'équipe) : isolation structurelle de
// la confidentialité — la correspondance médicale du médecin ne peut jamais fuiter
// vers l'Inbox d'équipe accessible à la secrétaire.
model Mailbox {
  id          String   @id @default(uuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id])
  address     String   @unique          // "ahmadalashry@reset-egypt.com"
  displayName String                    // "Dr Ahmad Al Ashry"
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  threads EmailThread[]
  emails  EmailMessage[]
}

// Fil de discussion : regroupe les emails d'une même conversation.
model EmailThread {
  id           String   @id @default(uuid())
  mailboxId    String
  mailbox      Mailbox  @relation(fields: [mailboxId], references: [id], onDelete: Cascade)
  subject      String
  participants String[]                 // emails des interlocuteurs (hors mailbox)
  patientId    String?                  // lié si un interlocuteur est un patient connu
  patient      Patient? @relation(fields: [patientId], references: [id])
  lastEmailAt  DateTime
  unreadCount  Int      @default(0)
  isArchived   Boolean  @default(false)
  isStarred    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  emails EmailMessage[]

  @@index([mailboxId, isArchived, lastEmailAt])
  @@index([mailboxId, isStarred])
  @@index([patientId])
}

// Email individuel (entrant ou sortant).
model EmailMessage {
  id           String      @id @default(uuid())
  mailboxId    String
  mailbox      Mailbox     @relation(fields: [mailboxId], references: [id], onDelete: Cascade)
  threadId     String
  thread       EmailThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  direction    Direction                // INBOUND | OUTBOUND (enum existant réutilisé)
  messageId    String      @unique       // header Message-ID RFC822
  inReplyTo    String?                  // header In-Reply-To
  references   String[]    @default([]) // header References
  fromAddress  String
  fromName     String?
  toAddresses  String[]
  ccAddresses  String[]    @default([])
  subject      String
  bodyText     String?     @db.Text
  bodyHtml     String?     @db.Text
  snippet      String                   // ~140 premiers caractères, pour la liste
  status       EmailStatus @default(RECEIVED)
  isRead       Boolean     @default(false)
  sentByUserId String?                  // qui a envoyé (OUTBOUND) — null pour INBOUND
  sentByUser   User?       @relation("EmailSentBy", fields: [sentByUserId], references: [id])
  sentAt       DateTime                 // date d'envoi (OUTBOUND) ou de réception (INBOUND)
  createdAt    DateTime    @default(now())

  attachments EmailAttachment[]

  @@index([threadId, sentAt])
  @@index([mailboxId, isRead])
  @@index([messageId])
}

// Pièce jointe : métadonnées en base, fichier dans Supabase Storage.
model EmailAttachment {
  id          String       @id @default(uuid())
  emailId     String
  email       EmailMessage @relation(fields: [emailId], references: [id], onDelete: Cascade)
  filename    String
  contentType String
  sizeBytes   Int
  storageKey  String                    // clé Supabase Storage : {mailboxId}/{emailId}/{filename}
  createdAt   DateTime     @default(now())

  @@index([emailId])
}

enum EmailStatus {
  RECEIVED      // email entrant reçu
  SENDING       // envoi en cours
  SENT          // envoyé avec succès
  FAILED        // échec d'envoi
}
