{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "installCommand": "cd ../.. && pnpm install --frozen-lockfile=false",
  "buildCommand": "cd ../.. && pnpm --filter @reset/api exec prisma generate",
  "rewrites": [{ "source": "/(.*)", "destination": "/api/index" }],
  "regions": ["fra1"]
}
