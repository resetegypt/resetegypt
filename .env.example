# ==========================================
#  Reset Egypt — Environment variables
# ==========================================
# Copie ce fichier en .env (gitignored) et remplis les valeurs.
# En prod, ces variables sont définies dans Vercel et Supabase.

# ====================== DATABASE (Supabase ou Postgres local) ======================
# Supabase : récupère ces URLs dans Supabase → Project Settings → Database
# - DATABASE_URL = "Transaction pooler" (port 6543) — utilisé par l'API en runtime
# - DIRECT_URL = "Session pooler" ou "Direct connection" (port 5432) — utilisé par les migrations
# IMPORTANT : ajoute ?pgbouncer=true&connection_limit=1 à la DATABASE_URL (pooler)
DATABASE_URL=postgresql://postgres.xxxx:PASSWORD@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
DIRECT_URL=postgresql://postgres.xxxx:PASSWORD@aws-0-eu-central-1.pooler.supabase.com:5432/postgres

# ====================== API ======================
NODE_ENV=production
API_PORT=3001
API_HOST=0.0.0.0
APP_URL=https://app.reset-egypt.com
API_URL=https://api.reset-egypt.com
# Origines autorisées (CORS) — virgules pour plusieurs
CORS_ORIGIN=https://app.reset-egypt.com,https://book.reset-egypt.com,https://reset-egypt.com

# ====================== AUTH ======================
# Génère avec : openssl rand -base64 32
JWT_SECRET=change-me-generate-with-openssl-rand-base64-32

# ====================== EMAIL ======================
# Préférence : Resend (production). À défaut : SMTP (dev/MailHog).
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxx
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM="Reset Egypt <noreply@reset-egypt.com>"

# ====================== MESSAGERIE PRATICIEN ======================
# Secret partagé entre le Cloudflare Email Worker et le webhook /inbound/email.
# Génère avec : openssl rand -base64 32
INBOUND_EMAIL_SECRET=change-me-generate-with-openssl-rand-base64-32
# Supabase Storage pour les pièces jointes (bucket privé "email-attachments")
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJxxxx...

# ====================== CACHE (futur) ======================
REDIS_URL=redis://localhost:6379

# ====================== FRONTEND (Vite) ======================
# Doit être PRÉFIXÉ par VITE_ pour être exposé au navigateur.
# En prod, défini dans Vercel pour chaque projet web et booking.
VITE_API_URL=https://api.reset-egypt.com

# ====================== CENTRE (placeholders) ======================
CENTER_NAME=Reset Egypt
CENTER_ADDRESS=N Teseen, New Cairo 1, Le Caire 11835
CENTER_PHONE=+201xxxxxxxxx
CENTER_TAX_ID=xxx-xxx-xxx
CENTER_COMMERCIAL_NUMBER=xxx-xxx
